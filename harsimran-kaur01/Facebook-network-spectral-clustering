        "print(\"STEP 5: ORTHOGONALIZATION (Gram-Schmidt Process)\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "def gram_schmidt(vectors):\n",
        "    \"\"\"Classical Gram-Schmidt orthogonalization\"\"\"\n",
        "    vectors = vectors.copy().astype(float)\n",
        "    m, n = vectors.shape\n",
        "    orthogonal = np.zeros((m, n))\n",
        "\n",
        "    for i in range(n):\n",
        "        orthogonal[:, i] = vectors[:, i]\n",
        "        # Subtract projections onto previous vectors\n",
        "        for j in range(i):\n",
        "            proj = np.dot(orthogonal[:, i], orthogonal[:, j])\n",
        "            orthogonal[:, i] -= proj * orthogonal[:, j]\n",
        "\n",
        "        # Normalize\n",
        "        norm = np.linalg.norm(orthogonal[:, i])\n",
        "        if norm > 1e-10:\n",
        "            orthogonal[:, i] /= norm\n",
        "\n",
        "    return orthogonal\n",
        "\n",
        "# Take 5 random vectors from adjacency matrix\n",
        "vectors = A[:20, :5]  # 20-dimensional vectors, 5 of them\n",
