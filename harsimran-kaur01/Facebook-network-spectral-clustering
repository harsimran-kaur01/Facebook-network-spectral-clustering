        "#REMOVE REDUNDANCY\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"STEP 4: REMOVE REDUNDANCY (Linear Independence → Basis Selection)\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "# Extract linearly independent rows from adjacency matrix\n",
        "def find_linearly_independent_rows(matrix):\n",
        "    \"\"\"Find a basis of linearly independent rows\"\"\"\n",
        "    M = matrix.copy().astype(float)\n",
        "    rows, cols = M.shape\n",
        "    independent_rows = []\n",
        "\n",
        "    for i in range(rows):\n",
        "        # Check if current row is linear combination of previous\n",
        "        if len(independent_rows) > 0:\n",
        "            prev_rows = M[independent_rows]\n",
        "            # Try to express row i as combination of previous\n",
        "            try:\n",
        "                coeffs = np.linalg.lstsq(prev_rows.T, M[i], rcond=None)[0]\n",
        "                reconstruction = prev_rows.T @ coeffs\n",
        "                if np.allclose(M[i], reconstruction, atol=1e-10):\n",
        "                    continue  # Row is linearly dependent\n",
        "            except:\n",
        "                pass\n",
        "        independent_rows.append(i)\n",
        "\n",
        "    return independent_rows\n",
        "\n",
        "# Find basis for adjacency matrix\n",
