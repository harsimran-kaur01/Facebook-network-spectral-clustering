        "# MATRIX SIMPLIFICATION\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"STEP 2: MATRIX SIMPLIFICATION (Gaussian Elimination → RREF)\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "def gaussian_elimination(matrix):\n",
        "    \"\"\"Perform Gaussian Elimination to get Row Echelon Form\"\"\"\n",
        "    M = matrix.copy().astype(float)\n",
        "    rows, cols = M.shape\n",
        "    rank = 0\n",
        "\n",
        "    for col in range(min(rows, cols)):\n",
        "        # Find pivot\n",
        "        pivot = np.argmax(np.abs(M[rank:, col])) + rank\n",
        "        if np.abs(M[pivot, col]) < 1e-10:\n",
        "            continue\n",
        "\n",
        "        # Swap rows\n",
        "        M[[rank, pivot]] = M[[pivot, rank]]\n",
        "\n",
        "        # Eliminate below\n",
        "        for row in range(rank + 1, rows):\n",
        "            factor = M[row, col] / M[rank, col]\n",
        "            M[row, col:] -= factor * M[rank, col:]\n",
        "\n",
        "        rank += 1\n",
        "        if rank == rows:\n",
        "            break\n",
        "\n",
        "    return M, rank\n",
        "\n",
        "def rref(matrix):\n",
        "    \"\"\"Compute Reduced Row Echelon Form\"\"\"\n",
        "    M = matrix.copy().astype(float)\n",
        "    rows, cols = M.shape\n",
        "    rank = 0\n",
        "    pivot_cols = []\n",
        "\n",
        "    for col in range(cols):\n",
        "        if rank >= rows:\n",
        "            break\n",
        "\n",
        "        # Find pivot\n",
        "        pivot = np.argmax(np.abs(M[rank:, col])) + rank\n",
        "        if np.abs(M[pivot, col]) < 1e-10:\n",
        "            continue\n",
        "\n",
        "        # Swap rows\n",
        "        M[[rank, pivot]] = M[[pivot, rank]]\n",
        "\n",
        "        # Scale pivot row to 1\n",
        "        M[rank] = M[rank] / M[rank, col]\n",
        "\n",
        "        # Eliminate all other rows\n",
        "        for row in range(rows):\n",
        "            if row != rank and np.abs(M[row, col]) > 1e-10:\n",
        "                M[row] = M[row] - M[row, col] * M[rank]\n",
        "\n",
        "        pivot_cols.append(col)\n",
        "        rank += 1\n",
        "\n",
        "    return M, rank, pivot_cols\n",
        "\n",
